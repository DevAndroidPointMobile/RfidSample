<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E3A5F"
        android:title="RFID Sample V2"
        android:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Bluetooth -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBluetooth"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:text="Bluetooth Connection"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="4dp" />

            <!-- Wired -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWired"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:text="Wired Connection"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="4dp" />

            <!-- Tap to Pair -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTapToPair"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:text="Tap to Pair"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="4dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="20dp"
                android:background="#DDDDDD" />

            <!-- Inventory -->
            <Button
                android:id="@+id/btnInventory"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:text="Inventory"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="4dp" />

            <!-- Inventory N Read -->
            <Button
                android:id="@+id/btnInventoryNRead"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:text="Inventory N Read"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="4dp" />

            <!-- Barcode -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBarcode"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:text="Barcode Scan"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="4dp" />

            <!-- Configuration -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfiguration"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Configuration"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="4dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>