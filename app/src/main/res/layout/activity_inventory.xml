<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="activity"
            type="device.apps.rfidsamplev2.sample.inventory.InventoryActivity" />

        <variable
            name="uniqueCount"
            type="int" />

        <variable
            name="isScanning"
            type="Boolean" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5"
        android:orientation="vertical"
        tools:context=".sample.inventory.InventoryActivity">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            android:background="@drawable/gradient_toolbar"
            android:elevation="2dp"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Inventory"
            app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"
            app:titleTextColor="@android:color/white" />

        <!-- List header: title + scanning dot + count chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Scanned Tags"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Blink while inventory trigger is held -->
            <View
                android:id="@+id/scan_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/circle_background"
                android:visibility="@{safeUnbox(isScanning) ? View.VISIBLE : View.GONE}"
                tools:visibility="visible" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_background"
                android:fontFamily="sans-serif-medium"
                android:minWidth="32dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="@{String.valueOf(uniqueCount)}"
                android:textAlignment="center"
                android:textColor="@color/brand_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="12" />
        </LinearLayout>

        <!-- Tag list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_inventory" />

        <!-- Sticky action bar -->
        <LinearLayout
            android:id="@+id/action_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_inventory"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@{safeUnbox(isScanning) ? @color/action_neutral : @color/brand_primary}"
                android:fontFamily="sans-serif-medium"
                android:onClick="@{activity::onToggleInventory}"
                android:text="@{safeUnbox(isScanning) ? `Stop Inventory` : `Start Inventory`}"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_inventory"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@android:color/white"
                tools:text="Start Inventory" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_clear"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-medium"
                android:onClick="@{activity::onClear}"
                android:text="Clear All"
                android:textAllCaps="false"
                android:textColor="@color/action_stop"
                android:textSize="15sp"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_clear"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/action_stop"
                app:strokeColor="@color/action_stop"
                app:strokeWidth="2dp" />
        </LinearLayout>
    </LinearLayout>
</layout>
