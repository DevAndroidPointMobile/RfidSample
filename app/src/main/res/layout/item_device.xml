<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="device"
            type="android.bluetooth.BluetoothDevice" />

        <variable
            name="listener"
            type="device.apps.rfidsamplev2.sample.bluetooth.callback.OnDeviceClickListener" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:clickable="true"
        android:focusable="true"
        android:onClick="@{() -> listener.onDeviceClicked(device)}"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:rippleColor="@color/brand_ripple"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <!-- Device icon chip -->
            <androidx.cardview.widget.CardView
                android:id="@+id/device_icon_chip"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardBackgroundColor="@color/brand_surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Device"
                    android:padding="12dp"
                    android:src="@drawable/ic_bluetooth"
                    app:tint="@color/brand_primary" />
            </androidx.cardview.widget.CardView>

            <!-- Device info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/arrow_icon"
                app:layout_constraintStart_toEndOf="@id/device_icon_chip"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:text="@{device.name}"
                    android:textColor="#212121"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="RF88 [DC:00:CF:11:11]" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@{device.address}"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    tools:text="DC:00:CF:11:11" />
            </LinearLayout>

            <!-- Trailing chevron -->
            <ImageView
                android:id="@+id/arrow_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Connect"
                android:src="@drawable/ic_arrow_forward"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/icon_neutral" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>
</layout>
